# ─── Telegram ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_MINIAPP_URL=https://manticthink.com/app
TELEGRAM_DEV_AUTH=false
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_GROUP_MODE=mention

# ─── AI Provider (ollama | openai | anthropic) ────────
AI_PROVIDER=ollama

# Ollama Cloud
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=nemotron-3-super

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://manticode:manticode@localhost:5432/manticode

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string

# ─── Server ───────────────────────────────────────────
PORT=3001
CORS_ORIGIN=https://manticthink.com
NODE_ENV=development
